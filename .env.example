# ── Docker Compose Environment Variables ──────────────
# Copy this file to .env and fill in the values
# Run: openssl rand -hex 32  to generate secure secrets

# ── Auth secrets (OBRIGATÓRIO — use valores fortes em produção) ────
JWT_SECRET=
JWT_REFRESH_SECRET=

# ── Banco de dados ─────────────────────────────────────
POSTGRES_PASSWORD=

# ── Evolution API Key ──────────────────────────────────
EVOLUTION_API_KEY=

# ── URLs da aplicação ──────────────────────────────────
APP_URL=https://api.seu-dominio.com
WEBHOOK_URL=https://api.seu-dominio.com

# ── CORS — origens permitidas (vírgula-separado) ───────
# Exemplo: https://app.seu-dominio.com,https://www.seu-dominio.com
CORS_ORIGINS=https://app.seu-dominio.com

# ── Frontend ───────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.seu-dominio.com
NEXT_PUBLIC_WS_URL=https://api.seu-dominio.com
NEXT_PUBLIC_APP_NAME=SistemaZapChat
NEXT_PUBLIC_APP_URL=https://app.seu-dominio.com
ALLOWED_ORIGINS=app.seu-dominio.com

# ── Anthropic (Claude) — opcional ─────────────────────
ANTHROPIC_API_KEY=

# ── VAPID — Push Notifications ────────────────────────
# Gerar com: node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(k)"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@sistemazapchat.com

# ── MinIO (Object Storage S3-compatible) ──────────────
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=whatsapp-media

# ── Sentry — monitoramento de erros ───────────────────
# API (Node.js/Fastify project)
SENTRY_DSN=https://38120033158ec0961994e7daf3f6d575@o4509828286054400.ingest.us.sentry.io/4511021131497472
# Web (Next.js project)
NEXT_PUBLIC_SENTRY_DSN=https://06eda8733dd90703584833236ec6cf21@o4509828286054400.ingest.us.sentry.io/4511021135560704
# Necessário apenas para upload de source maps no build de produção
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
