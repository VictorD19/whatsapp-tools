{
  "name": "whatsapp-tools",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @repo/database prisma generate",
    "db:migrate": "pnpm --filter @repo/database prisma migrate dev",
    "db:studio": "pnpm --filter @repo/database prisma studio"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0",
    "prettier": "^3.4.0"
  },
  "pnpm": {
    "overrides": {
      "typescript": "^5.9.3"
    }
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.30.3"
}
