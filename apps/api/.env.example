# ── App ────────────────────────────────
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3001

# ── Database ───────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/whatsapp_tools?schema=public

# ── Redis ──────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ───────────────────────────────
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-refresh-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Evolution API ──────────────────────
EVOLUTION_API_URL=http://localhost:8085
EVOLUTION_API_KEY=changeme-evolution-key
WEBHOOK_URL=http://host.docker.internal:3001

# ── IA ─────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
LLM_DEFAULT_MODEL=gpt-4o-mini

# ── Storage (MinIO / S3 / R2) ───────────
# MinIO local (dev):
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET=whatsapp-media
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_PUBLIC_URL=http://localhost:9000
MINIO_FORCE_PATH_STYLE=true
# Para S3: remover MINIO_FORCE_PATH_STYLE, atualizar endpoint/credenciais
# Para R2: MINIO_ENDPOINT=https://<account>.r2.cloudflarestorage.com
#          MINIO_FORCE_PATH_STYLE=false

# Push Notifications (VAPID) — gerar com: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@example.com
