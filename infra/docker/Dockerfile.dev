# ───────────────────────────────────────────────────────────
# Dockerfile.dev — imagem de dev compartilhada (api + web)
# pnpm pré-instalado, entrypoint inteligente
# ───────────────────────────────────────────────────────────

FROM node:20-alpine

RUN npm install -g pnpm@10

WORKDIR /app

COPY entrypoint.dev.sh /usr/local/bin/entrypoint.dev.sh
RUN sed -i 's/\r$//' /usr/local/bin/entrypoint.dev.sh && chmod +x /usr/local/bin/entrypoint.dev.sh

ENTRYPOINT ["sh", "/usr/local/bin/entrypoint.dev.sh"]
