// ────────────────────────────────────────────────
// WhatsApp Sales Platform — Prisma Schema
// Migrations:
//   20260303175033_init
//   20260303191346_add_message_tenant_relation
// ────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Plan ──────────────────────────────────────────

model Plan {
  id                      String    @id @default(cuid())
  name                    String
  slug                    String    @unique
  description             String?
  benefits                Json      @default("[]")
  maxInstances            Int       @default(3)
  maxUsers                Int       @default(5)
  maxAssistants           Int       @default(1)
  maxBroadcastsPerDay     Int       @default(5)
  maxContactsPerBroadcast Int       @default(500)
  price                   Decimal?  @db.Decimal(10, 2)
  isDefault               Boolean   @default(false)
  isActive                Boolean   @default(true)
  sortOrder               Int       @default(0)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  tenants Tenant[]

  @@index([isActive])
  @@index([sortOrder])
}

// ── Tenant ──────────────────────────────────────

model Tenant {
  id             String    @id @default(cuid())
  name           String
  slug           String    @unique
  planId         String
  protocolPrefix String    @default("SCHA")
  protocolSeq    Int       @default(999)
  locale         String    @default("pt-BR")
  timezone       String    @default("America/Sao_Paulo")
  currency       String    @default("BRL")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  plan          Plan       @relation(fields: [planId], references: [id])
  instances     Instance[]
  users         User[]
  contacts      Contact[]
  conversations Conversation[]
  messages      Message[]
  pipelines     Pipeline[]
  deals         Deal[]
  dealNotes     DealNote[]
  tags          Tag[]
  contactLists  ContactList[]
  notifications Notification[]

  @@index([planId])
}

// ── User ────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  tenantId     String
  email        String    @unique
  name         String
  password     String
  role         String    @default("agent")
  isSuperAdmin Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  conversations Conversation[] @relation("AssignedConversations")
  assignedDeals Deal[]         @relation("DealAssignee")
  dealNotes     DealNote[]     @relation("DealNoteAuthor")
  notifications Notification[]
  notificationPreferences NotificationPreference[]

  @@index([tenantId])
}

// ── Instance (WhatsApp) ─────────────────────────

enum InstanceStatus {
  CONNECTED
  CONNECTING
  DISCONNECTED
  BANNED
}

model Instance {
  id          String         @id @default(cuid())
  tenantId    String
  name        String
  phone       String?
  status      InstanceStatus @default(DISCONNECTED)
  evolutionId String         @unique
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  deletedAt   DateTime?

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  conversations Conversation[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([evolutionId])
}

// ── Contact ─────────────────────────────────────

model Contact {
  id        String    @id @default(cuid())
  tenantId  String
  phone     String
  name      String?
  avatarUrl String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant           Tenant             @relation(fields: [tenantId], references: [id])
  conversations    Conversation[]
  deals            Deal[]
  contactTags      ContactTag[]
  contactListItems ContactListItem[]

  @@unique([tenantId, phone])
  @@index([tenantId])
  @@index([tenantId, phone])
}

// ── Conversation ────────────────────────────────

enum ConversationStatus {
  PENDING
  OPEN
  CLOSE
}

model Conversation {
  id            String             @id @default(cuid())
  tenantId      String
  instanceId    String
  contactId     String
  assignedToId  String?
  protocol      String
  status        ConversationStatus @default(PENDING)
  tags          String[]           @default([])
  summary       String?
  unreadCount   Int                @default(0)
  lastMessageAt DateTime?
  closedAt      DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  deletedAt     DateTime?

  tenant     Tenant    @relation(fields: [tenantId], references: [id])
  instance   Instance  @relation(fields: [instanceId], references: [id])
  contact    Contact   @relation(fields: [contactId], references: [id])
  assignedTo User?     @relation("AssignedConversations", fields: [assignedToId], references: [id])
  messages   Message[]
  deals      Deal[]

  @@unique([tenantId, protocol])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, instanceId])
  @@index([contactId])
}

// ── Message ─────────────────────────────────────

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  STICKER
  LOCATION
  CONTACT
  UNKNOWN
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

model Message {
  id              String        @id @default(cuid())
  tenantId        String
  conversationId  String
  quotedMessageId String?
  fromMe          Boolean       @default(false)
  fromBot         Boolean       @default(false)
  body            String?
  type            MessageType   @default(TEXT)
  status          MessageStatus @default(PENDING)
  evolutionId     String?
  mediaUrl        String?
  sentAt          DateTime      @default(now())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  tenant        Tenant       @relation(fields: [tenantId], references: [id])
  conversation  Conversation @relation(fields: [conversationId], references: [id])
  quotedMessage Message?     @relation("QuotedMessage", fields: [quotedMessageId], references: [id])
  replies       Message[]    @relation("QuotedMessage")

  @@index([conversationId])
  @@index([tenantId])
  @@index([evolutionId])
}

// ── CRM: Pipeline & Deals ────────────────────────

enum PipelineStageType {
  ACTIVE
  WON
  LOST
}

model Pipeline {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant          @relation(fields: [tenantId], references: [id])
  stages PipelineStage[]
  deals  Deal[]

  @@index([tenantId])
}

model PipelineStage {
  id         String            @id @default(cuid())
  pipelineId String
  name       String
  color      String            @default("#6B7280")
  type       PipelineStageType @default(ACTIVE)
  order      Int
  isDefault  Boolean           @default(false)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  pipeline Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  deals    Deal[]

  @@unique([pipelineId, order])
  @@index([pipelineId])
}

model Deal {
  id             String    @id @default(cuid())
  tenantId       String
  pipelineId     String
  stageId        String
  contactId      String
  conversationId String?
  assignedToId   String?
  title          String?
  value          Decimal?  @db.Decimal(10, 2)
  wonAt          DateTime?
  lostAt         DateTime?
  lostReason     String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  pipeline     Pipeline      @relation(fields: [pipelineId], references: [id])
  stage        PipelineStage @relation(fields: [stageId], references: [id])
  contact      Contact       @relation(fields: [contactId], references: [id])
  conversation Conversation? @relation(fields: [conversationId], references: [id])
  assignedTo   User?         @relation("DealAssignee", fields: [assignedToId], references: [id])
  notes        DealNote[]

  @@index([tenantId])
  @@index([tenantId, contactId])
  @@index([tenantId, stageId])
  @@index([conversationId])
}

model DealNote {
  id        String   @id @default(cuid())
  dealId    String
  tenantId  String
  authorId  String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id])
  author User   @relation("DealNoteAuthor", fields: [authorId], references: [id])

  @@index([dealId])
  @@index([tenantId])
}

// ── CRM: Tags ─────────────────────────────────────

model Tag {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  color     String   @default("#6B7280")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant       @relation(fields: [tenantId], references: [id])
  contacts ContactTag[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model ContactTag {
  contactId String
  tagId     String
  createdAt DateTime @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
  @@index([tagId])
}

// ── Contact Lists ─────────────────────────────────

enum ContactListSource {
  GROUP_EXTRACT
  CSV_IMPORT
  MANUAL
  CRM_FILTER
}

model ContactList {
  id           String            @id @default(cuid())
  tenantId     String
  name         String
  description  String?
  source       ContactListSource @default(MANUAL)
  contactCount Int               @default(0)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  deletedAt    DateTime?

  tenant Tenant            @relation(fields: [tenantId], references: [id])
  items  ContactListItem[]

  @@index([tenantId])
}

model ContactListItem {
  contactListId String
  contactId     String
  addedAt       DateTime @default(now())

  contactList ContactList @relation(fields: [contactListId], references: [id], onDelete: Cascade)
  contact     Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([contactListId, contactId])
  @@index([contactId])
}

// ── Notifications ─────────────────────────────────

enum NotificationType {
  NEW_MESSAGE
  CONVERSATION_ASSIGNED
  CONVERSATION_TRANSFERRED
  CONVERSATIONS_IMPORTED
  INSTANCE_CONNECTED
  INSTANCE_DISCONNECTED
  INSTANCE_BANNED
  DEAL_WON
  DEAL_LOST
  DEAL_ASSIGNED
  GROUP_EXTRACTION_COMPLETED
}

model Notification {
  id        String           @id @default(cuid())
  tenantId  String
  userId    String
  type      NotificationType
  title     String
  body      String
  read      Boolean          @default(false)
  readAt    DateTime?
  data      Json?
  createdAt DateTime         @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([userId, read])
  @@index([userId, createdAt])
}

model NotificationPreference {
  id      String           @id @default(cuid())
  userId  String
  type    NotificationType
  inApp   Boolean          @default(true)
  browser Boolean          @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([userId])
}
