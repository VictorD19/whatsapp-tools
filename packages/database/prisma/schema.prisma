// ────────────────────────────────────────────────
// WhatsApp Sales Platform — Prisma Schema
// Migrations:
//   20260303175033_init
//   20260303191346_add_message_tenant_relation
// ────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Plan ──────────────────────────────────────────

model Plan {
  id                      String    @id @default(cuid())
  name                    String
  slug                    String    @unique
  description             String?
  benefits                Json      @default("[]")
  maxInstances            Int       @default(3)
  maxUsers                Int       @default(5)
  maxAssistants           Int       @default(1)
  maxBroadcastsPerDay     Int       @default(5)
  maxContactsPerBroadcast Int       @default(500)
  price                   Decimal?  @db.Decimal(10, 2)
  isDefault               Boolean   @default(false)
  isActive                Boolean   @default(true)
  sortOrder               Int       @default(0)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  tenants Tenant[]

  @@index([isActive])
  @@index([sortOrder])
}

// ── Tenant ──────────────────────────────────────

model Tenant {
  id             String    @id @default(cuid())
  name           String
  slug           String    @unique
  planId         String
  protocolPrefix String    @default("SCHA")
  protocolSeq    Int       @default(999)
  locale         String    @default("pt-BR")
  timezone       String    @default("America/Sao_Paulo")
  currency       String    @default("BRL")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  plan          Plan       @relation(fields: [planId], references: [id])
  instances     Instance[]
  users         User[]
  contacts      Contact[]
  conversations Conversation[]
  messages      Message[]
  pipelines     Pipeline[]
  deals         Deal[]
  dealNotes     DealNote[]
  tags          Tag[]
  contactLists  ContactList[]
  notifications Notification[]
  broadcasts    Broadcast[]
  assistants       Assistant[]
  knowledgeBases   KnowledgeBase[]
  aiTools          AiTool[]
  messageReactions MessageReaction[]
  followUps        FollowUp[]
  assistantSetting AssistantSetting?
  integrations    Integration[]
  calendarEvents  CalendarEvent[]

  @@index([planId])
}

// ── User ────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  tenantId     String
  email        String    @unique
  name         String
  password     String
  role         String    @default("agent")
  isSuperAdmin Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  conversations Conversation[] @relation("AssignedConversations")
  assignedDeals Deal[]         @relation("DealAssignee")
  dealNotes     DealNote[]     @relation("DealNoteAuthor")
  notifications Notification[]
  notificationPreferences NotificationPreference[]
  pushSubscriptions PushSubscription[]
  broadcastsCreated Broadcast[] @relation("BroadcastCreator")
  followUpsCreated  FollowUp[]  @relation("FollowUpCreator")
  integrations      Integration[]

  @@index([tenantId])
}

// ── Instance (WhatsApp) ─────────────────────────

enum InstanceStatus {
  CONNECTED
  CONNECTING
  DISCONNECTED
  BANNED
}

model Instance {
  id          String         @id @default(cuid())
  tenantId    String
  name        String
  phone       String?
  status      InstanceStatus @default(DISCONNECTED)
  evolutionId        String         @unique
  defaultAssistantId String?
  createdAt          DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  deletedAt   DateTime?

  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  conversations      Conversation[]
  broadcastInstances BroadcastInstance[]
  defaultAssistant   Assistant?          @relation("InstanceDefaultAssistant", fields: [defaultAssistantId], references: [id], onDelete: SetNull)

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([evolutionId])
}

// ── Contact ─────────────────────────────────────

model Contact {
  id        String    @id @default(cuid())
  tenantId  String
  phone     String
  name      String?
  avatarUrl String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  conversations       Conversation[]
  deals               Deal[]
  contactTags         ContactTag[]
  contactListItems    ContactListItem[]
  broadcastRecipients BroadcastRecipient[]

  @@unique([tenantId, phone])
  @@index([tenantId])
  @@index([tenantId, phone])
}

// ── Conversation ────────────────────────────────

enum ConversationStatus {
  PENDING
  OPEN
  CLOSE
}

model Conversation {
  id            String             @id @default(cuid())
  tenantId      String
  instanceId    String
  contactId     String
  assignedToId  String?
  protocol      String
  status        ConversationStatus @default(PENDING)
  tags          String[]           @default([])
  summary       String?
  unreadCount   Int                @default(0)
  lastMessageAt DateTime?
  closedAt          DateTime?
  assistantPausedAt DateTime?
  aiThreadSummary   String?            @db.Text
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?

  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  instance   Instance   @relation(fields: [instanceId], references: [id])
  contact    Contact    @relation(fields: [contactId], references: [id])
  assignedTo User?      @relation("AssignedConversations", fields: [assignedToId], references: [id])
  messages   Message[]
  deals      Deal[]
  followUps  FollowUp[]

  @@unique([tenantId, protocol])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, instanceId])
  @@index([contactId])
}

// ── Message ─────────────────────────────────────

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
  STICKER
  LOCATION
  CONTACT
  UNKNOWN
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

model Message {
  id              String        @id @default(cuid())
  tenantId        String
  conversationId  String
  quotedMessageId String?
  fromMe          Boolean       @default(false)
  fromBot         Boolean       @default(false)
  body            String?
  type            MessageType   @default(TEXT)
  status          MessageStatus @default(PENDING)
  evolutionId     String?
  mediaUrl        String?
  senderJid       String?
  senderName      String?
  sentAt          DateTime      @default(now())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  tenant        Tenant            @relation(fields: [tenantId], references: [id])
  conversation  Conversation      @relation(fields: [conversationId], references: [id])
  quotedMessage Message?          @relation("QuotedMessage", fields: [quotedMessageId], references: [id])
  replies       Message[]         @relation("QuotedMessage")
  reactions     MessageReaction[]

  @@index([conversationId])
  @@index([conversationId, sentAt(sort: Desc)])
  @@index([tenantId])
  @@index([evolutionId])
}

// ── Message Reactions ────────────────────────────

model MessageReaction {
  id        String   @id @default(cuid())
  tenantId  String
  messageId String
  senderJid String
  emoji     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, senderJid])
  @@index([tenantId])
  @@index([messageId])
}

// ── CRM: Pipeline & Deals ────────────────────────

enum PipelineStageType {
  ACTIVE
  WON
  LOST
}

model Pipeline {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant          @relation(fields: [tenantId], references: [id])
  stages PipelineStage[]
  deals  Deal[]

  @@index([tenantId])
}

model PipelineStage {
  id         String            @id @default(cuid())
  pipelineId String
  name       String
  color      String            @default("#6B7280")
  type       PipelineStageType @default(ACTIVE)
  order      Int
  isDefault  Boolean           @default(false)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  pipeline Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  deals    Deal[]

  @@unique([pipelineId, order])
  @@index([pipelineId])
}

model Deal {
  id             String    @id @default(cuid())
  tenantId       String
  pipelineId     String
  stageId        String
  contactId      String
  conversationId String?
  assignedToId   String?
  title          String?
  value          Decimal?  @db.Decimal(10, 2)
  wonAt          DateTime?
  lostAt         DateTime?
  lostReason     String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  pipeline     Pipeline      @relation(fields: [pipelineId], references: [id])
  stage        PipelineStage @relation(fields: [stageId], references: [id])
  contact      Contact       @relation(fields: [contactId], references: [id])
  conversation Conversation? @relation(fields: [conversationId], references: [id])
  assignedTo   User?         @relation("DealAssignee", fields: [assignedToId], references: [id])
  notes        DealNote[]
  followUps    FollowUp[]

  @@index([tenantId])
  @@index([tenantId, contactId])
  @@index([tenantId, stageId])
  @@index([conversationId])
}

model DealNote {
  id        String   @id @default(cuid())
  dealId    String
  tenantId  String
  authorId  String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id])
  author User   @relation("DealNoteAuthor", fields: [authorId], references: [id])

  @@index([dealId])
  @@index([tenantId])
}

// ── CRM: Tags ─────────────────────────────────────

model Tag {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  color     String   @default("#6B7280")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant       @relation(fields: [tenantId], references: [id])
  contacts ContactTag[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model ContactTag {
  contactId String
  tagId     String
  createdAt DateTime @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
  @@index([tagId])
}

// ── Contact Lists ─────────────────────────────────

enum ContactListSource {
  GROUP_EXTRACT
  CSV_IMPORT
  MANUAL
  CRM_FILTER
}

model ContactList {
  id           String            @id @default(cuid())
  tenantId     String
  name         String
  description  String?
  source       ContactListSource @default(MANUAL)
  contactCount Int               @default(0)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  deletedAt    DateTime?

  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  items            ContactListItem[]
  broadcastSources BroadcastSource[]

  @@index([tenantId])
}

model ContactListItem {
  contactListId String
  contactId     String
  addedAt       DateTime @default(now())

  contactList ContactList @relation(fields: [contactListId], references: [id], onDelete: Cascade)
  contact     Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([contactListId, contactId])
  @@index([contactId])
}

// ── Broadcasts ───────────────────────────────────

enum BroadcastStatus {
  DRAFT
  SCHEDULED
  RUNNING
  PAUSED
  COMPLETED
  FAILED
  CANCELLED
}

enum BroadcastMessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
}

enum BroadcastRecipientStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

enum BroadcastSourceType {
  CONTACT_LIST
  GROUP
}

model Broadcast {
  id             String               @id @default(cuid())
  tenantId       String
  createdById    String
  name           String
  status         BroadcastStatus      @default(DRAFT)
  messageType    BroadcastMessageType @default(TEXT)
  messageTexts   String[]             @default([])
  mediaUrl       String?
  caption        String?
  fileName       String?
  delay          Int                  @default(5)
  totalCount     Int                  @default(0)
  sentCount      Int                  @default(0)
  failedCount    Int                  @default(0)
  scheduledAt    DateTime?
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  deletedAt      DateTime?

  tenant     Tenant               @relation(fields: [tenantId], references: [id])
  createdBy  User                 @relation("BroadcastCreator", fields: [createdById], references: [id])
  instances  BroadcastInstance[]
  sources    BroadcastSource[]
  recipients BroadcastRecipient[]
  variations BroadcastVariation[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([status, scheduledAt])
}

model BroadcastVariation {
  id           String               @id @default(cuid())
  broadcastId  String
  messageType  BroadcastMessageType @default(TEXT)
  text         String               @default("")
  mediaUrl     String?
  fileName     String?
  sortOrder    Int                  @default(0)
  createdAt    DateTime             @default(now())

  broadcast    Broadcast            @relation(fields: [broadcastId], references: [id], onDelete: Cascade)

  @@index([broadcastId])
}

model BroadcastInstance {
  broadcastId String
  instanceId  String

  broadcast Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  instance  Instance  @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@id([broadcastId, instanceId])
  @@index([instanceId])
}

model BroadcastSource {
  id            String              @id @default(cuid())
  broadcastId   String
  sourceType    BroadcastSourceType
  contactListId String?
  groupJid      String?
  groupName     String?

  broadcast   Broadcast    @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  contactList ContactList? @relation(fields: [contactListId], references: [id])

  @@index([broadcastId])
}

model BroadcastRecipient {
  id           String                   @id @default(cuid())
  broadcastId  String
  contactId    String
  phone        String
  name         String?
  status       BroadcastRecipientStatus @default(PENDING)
  sentAt       DateTime?
  failedReason String?

  broadcast Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  contact   Contact   @relation(fields: [contactId], references: [id])

  @@index([broadcastId, status])
  @@index([contactId])
}

// ── Notifications ─────────────────────────────────

enum NotificationType {
  NEW_MESSAGE
  CONVERSATION_ASSIGNED
  CONVERSATION_TRANSFERRED
  CONVERSATIONS_IMPORTED
  INSTANCE_CONNECTED
  INSTANCE_DISCONNECTED
  INSTANCE_BANNED
  DEAL_WON
  DEAL_LOST
  DEAL_ASSIGNED
  GROUP_EXTRACTION_COMPLETED
  BROADCAST_COMPLETED
  BROADCAST_FAILED
  FOLLOW_UP_DUE
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint])
  @@index([userId])
}

model Notification {
  id        String           @id @default(cuid())
  tenantId  String
  userId    String
  type      NotificationType
  title     String
  body      String
  read      Boolean          @default(false)
  readAt    DateTime?
  data      Json?
  createdAt DateTime         @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([userId, read])
  @@index([userId, createdAt])
}

model NotificationPreference {
  id      String           @id @default(cuid())
  userId  String
  type    NotificationType
  inApp   Boolean          @default(true)
  browser Boolean          @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([userId])
}

// ── Follow-ups ───────────────────────────────────

enum FollowUpType {
  MESSAGE
  CALL
  MEETING
  PROPOSAL
  PAYMENT
}

enum FollowUpMode {
  REMINDER
  AUTOMATIC
}

enum FollowUpStatus {
  PENDING
  NOTIFIED
  SENT
  CANCELLED
}

model FollowUp {
  id             String         @id @default(cuid())
  tenantId       String
  conversationId String
  dealId         String?
  createdById    String
  type           FollowUpType
  mode           FollowUpMode   @default(REMINDER)
  status         FollowUpStatus @default(PENDING)
  message        String?
  mediaKey       String?
  mediaFilename  String?
  scheduledAt    DateTime
  notifiedAt     DateTime?
  sentAt         DateTime?
  cancelledAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  conversation Conversation @relation(fields: [conversationId], references: [id])
  deal         Deal?        @relation(fields: [dealId], references: [id])
  createdBy    User         @relation("FollowUpCreator", fields: [createdById], references: [id])

  @@index([tenantId])
  @@index([conversationId])
  @@index([dealId])
  @@index([status, scheduledAt])
}

// ── AI: Assistant Settings ──────────────────────

model AssistantSetting {
  id           String   @id @default(cuid())
  tenantId     String   @unique
  openaiApiKey String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

// ── AI: Assistants ──────────────────────────────

model Assistant {
  id                 String    @id @default(cuid())
  tenantId           String
  name               String
  description        String?
  avatarUrl          String?
  avatarEmoji        String?
  model              String    @default("gpt-4o-mini")
  systemPrompt       String    @db.Text
  waitTimeSeconds    Int       @default(5)
  isActive           Boolean   @default(true)
  handoffKeywords    String[]
  audioResponseMode  String    @default("never")
  voiceId            String    @default("pt-BR-FranciscaNeural")

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?

  tenant             Tenant              @relation(fields: [tenantId], references: [id])
  knowledgeBases     AssistantKnowledgeBase[]
  tools              AssistantTool[]
  instanceDefaults   Instance[]          @relation("InstanceDefaultAssistant")

  @@index([tenantId])
}

// ── AI: Knowledge Base ──────────────────────────

model KnowledgeBase {
  id          String    @id @default(cuid())
  tenantId    String
  name        String
  description String?
  isActive    Boolean   @default(true)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  sources     KnowledgeSource[]
  assistants  AssistantKnowledgeBase[]

  @@index([tenantId])
}

model KnowledgeSource {
  id              String              @id @default(cuid())
  knowledgeBaseId String
  tenantId        String
  type            KnowledgeSourceType
  name            String
  originalUrl     String?
  fileKey         String?
  fileMimeType    String?
  status          IngestionStatus     @default(PENDING)
  errorMessage    String?

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  knowledgeBase   KnowledgeBase       @relation(fields: [knowledgeBaseId], references: [id])
  chunks          KnowledgeChunk[]

  @@index([knowledgeBaseId])
  @@index([tenantId])
}

model KnowledgeChunk {
  id         String   @id @default(cuid())
  sourceId   String
  tenantId   String
  content    String   @db.Text
  embedding  Unsupported("vector(1536)")
  chunkIndex Int

  source     KnowledgeSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([sourceId])
  @@index([tenantId])
}

// ── AI: Tools ───────────────────────────────────

model AiTool {
  id          String      @id @default(cuid())
  tenantId    String
  name        String
  description String?
  type        AiToolType
  config      Json        @default("{}")
  isActive    Boolean     @default(true)

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  assistants  AssistantTool[]

  @@index([tenantId])
}

// ── AI: Junction Tables ─────────────────────────

model AssistantKnowledgeBase {
  assistantId     String
  knowledgeBaseId String
  createdAt       DateTime @default(now())

  assistant       Assistant     @relation(fields: [assistantId], references: [id], onDelete: Cascade)
  knowledgeBase   KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)

  @@id([assistantId, knowledgeBaseId])
}

model AssistantTool {
  assistantId String
  aiToolId    String
  createdAt   DateTime @default(now())

  assistant   Assistant @relation(fields: [assistantId], references: [id], onDelete: Cascade)
  aiTool      AiTool    @relation(fields: [aiToolId], references: [id], onDelete: Cascade)

  @@id([assistantId, aiToolId])
}

// ── AI Enums ────────────────────────────────────

enum KnowledgeSourceType {
  FILE
  URL
  TEXT
}

enum IngestionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum AiToolType {
  BUSCAR_CONTATO
  CRIAR_CONTATO
  ADICIONAR_TAG
  CRIAR_DEAL
  TRANSFERIR_HUMANO
  WEBHOOK_EXTERNO
  SETAR_ETAPA_PIPELINE
  CONSULTAR_DISPONIBILIDADE
  CRIAR_EVENTO
}

// ── Integrations ──────────────────────────────────

model Integration {
  id                String    @id @default(cuid())
  tenantId          String
  userId            String
  provider          String              // "google_calendar", "outlook"
  providerAccountId String              // email da conta Google
  accessToken       String?   @db.Text  // criptografado AES-256
  refreshToken      String?   @db.Text  // criptografado AES-256
  tokenExpiresAt    DateTime?
  scopes            String[]
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  user           User            @relation(fields: [userId], references: [id])
  calendarEvents CalendarEvent[]

  @@index([tenantId])
  @@index([userId])
}

model CalendarEvent {
  id               String   @id @default(cuid())
  tenantId         String
  integrationId    String
  externalEventId  String
  title            String
  description      String?
  startAt          DateTime
  endAt            DateTime
  timezone         String   @default("America/Sao_Paulo")
  location         String?
  attendees        Json?
  hangoutLink      String?
  status           String   @default("confirmed")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  integration Integration @relation(fields: [integrationId], references: [id])
  tenant      Tenant      @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([integrationId])
  @@index([startAt])
}
